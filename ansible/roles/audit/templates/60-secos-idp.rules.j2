## idp-node — Keycloak + OpenLDAP (rootless containers under secos)
-w /var/lib/secos/secos/idp/keycloak/  -p wa -k keycloak_cfg
-w /var/lib/secos/secos/idp/openldap/  -p wa -k ldap_cfg
-w /var/lib/secos/secos/idp/compose.yml -p wa -k idp_compose
-w /var/lib/secos/.config/systemd/user/secos-idp.service -p wa -k idp_unit
