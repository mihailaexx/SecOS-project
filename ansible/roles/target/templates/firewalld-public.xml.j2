<?xml version="1.0" encoding="utf-8"?>
<zone>
  <short>Public</short>
  <rule family="ipv4">
    <source address="{{ secos_hypervisor_ip }}/32"/>
    <port port="22" protocol="tcp"/>
    <accept/>
  </rule>
{% for host in groups['bastions'] %}
  <rule family="ipv4">
    <source address="{{ hostvars[host].ansible_host }}/32"/>
    <port port="22" protocol="tcp"/>
    <accept/>
  </rule>
  <rule family="ipv4">
    <source address="{{ hostvars[host].ansible_host }}/32"/>
    <port port="5432" protocol="tcp"/>
    <accept/>
  </rule>
{% endfor %}
</zone>
