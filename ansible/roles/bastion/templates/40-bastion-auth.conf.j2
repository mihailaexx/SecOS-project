UsePAM yes
PasswordAuthentication no
PubkeyAuthentication no
KbdInteractiveAuthentication yes
AuthenticationMethods keyboard-interactive

# Provisioning account bypasses OIDC via key auth (cloud-init injects the key).
# Human accounts (m.bulushev / admin1) still flow through keyboard-interactive
# → pam-keycloak-oidc → Keycloak. Key-only is a hardening upgrade over the
# old password bypass for the surrogate vagrant account.
Match User ansible
    PubkeyAuthentication yes
    PasswordAuthentication no
    AuthenticationMethods publickey
